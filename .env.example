# OpenAI
OPENAI_API_KEY=sk-...

# Transporte de WhatsApp (provedor). Atual: evolution. Isolado atras do MessagingGateway,
# trocavel por outro adapter (ex.: waha) sem mexer no app.py — basta um novo adapter + este valor.
TRANSPORT_PROVIDER=evolution

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE=dental-bot
WEBHOOK_API_KEY=your-webhook-api-key
# A Evolution API v2 envia a apikey somente no corpo JSON do webhook (nao em header),
# formato que a validacao por header/query nao reconhece. Se nao houver como configurar
# um header na Evolution, defina WEBHOOK_AUTH_DISABLED=true para pular a auth APENAS do
# /webhook/message (o /webhook/reload-config continua protegido).
WEBHOOK_AUTH_DISABLED=false
ADMIN_API_KEY=change-me-to-a-strong-secret-key

# Ambiente (production | development). Em production, ADMIN_API_KEY e obrigatoria.
ENVIRONMENT=development

# Google Calendar
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Database
DATABASE_PATH=./data/dental.db

# Doctor WhatsApp (for alerts)
DOCTOR_PHONE=5511999999999

# Runtime
HOST=0.0.0.0
PORT=3000
WORKERS=1
ENABLE_APPOINTMENT_CONFIRMATION_SCHEDULER=1

